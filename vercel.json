{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "functions": {
    "api/frd-generate.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/bot-persona-flow.html", "destination": "/bot-persona-flow.html" },
    { "source": "/api/frd-generate", "destination": "/api/frd-generate" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
