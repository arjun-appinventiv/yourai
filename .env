# config — reads from .env
# Frontend environment variables (must start with VITE_ for browser access)
# Secret keys (LLM, DB, S3) live in the BACKEND .env only — never here.

# Backend API base URL
# In development with Vite proxy, leave empty so fetch('/api/...') uses the proxy.
# In production, set to the full backend URL (e.g. https://api.yourai.com)
VITE_API_URL=

# App
VITE_APP_NAME=YourAI
